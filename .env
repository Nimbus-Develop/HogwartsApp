# Precargar datos de ejemplo al iniciar los contenedores
# true  → ejecuta los INSERT del init SQL
# false → solo crea el schema (tablas vacías)
PRELOAD_DATA=true

# Contraseñas (cambiar en producción)
MARIADB_ROOT_PASSWORD=password123
MARIADB_PASSWORD=password123
ORACLE_PASSWORD=password123
APP_USER_PASSWORD=password123